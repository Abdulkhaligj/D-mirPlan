{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and fitness logs",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "updatedAt": { "type": "integer" },
        "lastActive": { "type": "integer" },
        "weight": { "type": "number" },
        "programDays": { "type": "integer" },
        "premium": { "type": "boolean" },
        "premiumUntil": { "type": "integer" },
        "premiumPlan": { "type": "string" },
        "data": { "type": "object" }
      }
    },
    "PublicConfig": {
      "title": "PublicConfig",
      "description": "Global application public settings",
      "type": "object",
      "properties": {
        "paymentLink": { "type": "string" },
        "price": { "type": "string" },
        "whatsapp": { "type": "string" }
      }
    },
    "SecretConfig": {
      "title": "SecretConfig",
      "description": "Global application private settings",
      "type": "object",
      "properties": {
        "anthropicKey": { "type": "string" }
      }
    },
    "PaymentRequest": {
      "title": "PaymentRequest",
      "description": "Premium purchase request from a user to the admin",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "senderName": { "type": "string" },
        "senderCardLast4": { "type": "string" },
        "amount": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "integer" }
      }
    },
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "description": "Weekly volume lifted by a user for the leaderboard",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "weeklyVolume": { "type": "number" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["userId", "name", "weeklyVolume", "updatedAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment receipt for user subscription",
      "type": "object",
      "properties": {
        "date": { "type": "integer" },
        "amount": { "type": "string" },
        "cardUsed": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "failed"] }
      },
      "required": ["date", "amount", "cardUsed", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and exercise/nutrition logs"
    },
    "users/{userId}/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment records for the user"
    },
    "config/public": {
      "schema": "PublicConfig",
      "description": "Public layout and pricing config"
    },
    "config/secret": {
      "schema": "SecretConfig",
      "description": "Secret configuration keys"
    },
    "paymentRequests/{requestId}": {
      "schema": "PaymentRequest",
      "description": "Pending and past premium purchase requests"
    },
    "leaderboard/{userId}": {
      "schema": "LeaderboardEntry",
      "description": "Weekly volume lifted for community leaderboard"
    }
  }
}
